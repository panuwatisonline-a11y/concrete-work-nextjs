# Copy to .env.local and fill from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only: Project Settings → API → service_role (required for instant signup without email confirmation)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: used when request headers do not include host (e.g. some scripts)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: e.g. http://localhost:3000
# - Redirect URLs: add http://localhost:3000/auth/callback (and production URL + /auth/callback)
#   After password reset, users land on /auth/update-password via callback — same callback URL is enough.
